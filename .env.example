# CS:GO 2026 Server - Environment Variables
# Copy to /srv/csgo/.env and fill in values
# IMPORTANT: Quote values containing special characters (&, !, *, etc.)

# Server join password (required for players to connect)
SERVER_PASSWORD='changeme'

# RCON password (remote admin console - set something strong)
RCON_PASSWORD='changeme'

# Steam Game Server Login Token
# Get one at: https://steamcommunity.com/dev/managegameservers
# App ID: 4465480 (CS:GO 2026 standalone)
SRCDS_TOKEN=

# Steam Web API Key (enables workshop map downloads)
# Get one at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
